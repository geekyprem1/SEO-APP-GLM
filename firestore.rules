rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can read/write only their own user document and its subcollections.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subColl=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Everything else is server-only (Cloud Functions use the Admin SDK,
    // which bypasses these rules). Clients are denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
